# Required - Discord Bot
# Discord bot token used by the runtime Discord client.
BOT_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Discord application client ID used for bot startup and OAuth fallback.
CLIENT_ID=123456789012345678

# Optional - Discord OAuth Dashboard Login
# Defaults DISCORD_CLIENT_ID to CLIENT_ID when omitted.
DISCORD_CLIENT_ID=123456789012345678
# Required for dashboard Discord OAuth login in environments where login is used.
DISCORD_CLIENT_SECRET=replace-with-discord-oauth-client-secret
# Must exactly match the Discord Developer Portal OAuth2 redirect URI.
DISCORD_REDIRECT_URI=https://dashboard.hoakfamily.web.id/api/v1/auth/callback

# Required - Database
DATABASE_URL=postgresql://postgres.xxx:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres

# API
API_PORT=3000

# Dashboard
# URL users should return to after successful Discord OAuth login.
DASHBOARD_URL=https://dashboard.hoakfamily.web.id

# Sessions
# Duration in milliseconds. Default: 28800000 (8 hours).
SESSION_DURATION=28800000
# HttpOnly dashboard session cookie name. Default: hoak_session.
COOKIE_NAME=hoak_session
# Cleanup interval in milliseconds for future scheduled cleanup. Default: 3600000 (1 hour).
SESSION_CLEANUP_INTERVAL=3600000

# Application
NODE_ENV=production
LOG_LEVEL=info

# Authorization
# Optional primary guild override. Falls back to config/bot.json guildId.
GUILD_ID=123456789012345678
# Optional comma-separated bot/dashboard owner override IDs. Falls back to config/bot.json ownerIds.
OWNER_IDS=123456789012345678,987654321098765432
