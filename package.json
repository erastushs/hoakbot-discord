{
  "name": "hoakbot",
  "version": "1.0.0",
  "description": "Hoak Bot — A modular Discord bot for the Hoak Family community",
  "private": true,
  "main": "dist/bootstrap.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/bootstrap.ts",
    "start": "node dist/bootstrap.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit",
    "deploy:commands": "tsx scripts/deploy-commands.ts",
    "migrate": "tsx scripts/migrate.ts"
  },
  "keywords": [
    "discord",
    "bot"
  ],
  "author": "Erastus HS",
  "license": "UNLICENSED",
  "type": "module",
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.9.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0"
  },
  "dependencies": {
    "@discordjs/collection": "^2.1.1",
    "@discordjs/rest": "^2.6.1",
    "@discordjs/voice": "^0.19.2",
    "discord.js": "^14.26.4",
    "dotenv": "^16.6.1",
    "libsodium-wrappers": "^0.7.16",
    "pino": "^9.14.0",
    "pino-pretty": "^11.3.0",
    "postgres": "^3.4.9",
    "zod": "^3.25.76"
  }
}
