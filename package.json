{
  "name": "hoakbot",
  "version": "3.2.2",
  "description": "Hoak Bot — A modular Discord bot for the Hoak Family community",
  "private": true,
  "main": "dist/bootstrap.js",
  "scripts": {
    "build": "tsc && npm run dashboard:build",
    "dev": "tsx watch src/bootstrap.ts",
    "start": "node dist/bootstrap.js",
    "lint": "eslint src/ dashboard/",
    "lint:fix": "eslint src/ dashboard/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit && tsc -p dashboard/tsconfig.json --noEmit",
    "test": "vitest run && npm run dashboard:test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "deploy:commands": "tsx scripts/deploy-commands.ts",
    "list:commands": "tsx scripts/list-commands.ts",
    "clear:global-commands": "tsx scripts/clear-global-commands.ts",
    "migrate": "tsx scripts/migrate.ts",
    "dashboard:dev": "vite --config dashboard/vite.config.ts",
    "dashboard:build": "vite build --config dashboard/vite.config.ts",
    "dashboard:test": "vitest run --config dashboard/vite.config.ts"
  },
  "keywords": [
    "discord",
    "bot"
  ],
  "author": "Erastus HS",
  "license": "UNLICENSED",
  "type": "module",
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@discordjs/collection": "^2.1.1",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/rest": "^2.6.1",
    "@discordjs/voice": "^0.19.2",
    "@napi-rs/canvas": "^1.0.2",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.3",
    "discord.js": "^14.26.4",
    "dotenv": "^16.6.1",
    "jsdom": "^29.1.1",
    "libsodium-wrappers": "^0.7.16",
    "lucide-react": "^1.23.0",
    "opusscript": "^0.0.8",
    "pino": "^9.14.0",
    "pino-pretty": "^11.3.0",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.3",
    "zod": "^3.25.76"
  }
}
